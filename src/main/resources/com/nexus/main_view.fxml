<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.nexus.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #16171a;">
            <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
            <TextField fx:id="searchField" promptText="Search your workspace..." style="-fx-background-radius: 20;" HBox.hgrow="ALWAYS" />
            <Button fx:id="scanButton" onAction="#handleScan" style = "-fx-text-fill: white; -fx-font-weight: bold;" text="Scan Folder" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="200" spacing="10" style="-fx-background-color: #20252b;">
            <padding><Insets left="15" right="15" top="20" /></padding>
            <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 12;" text="COLLEGE WORK" />
            <Button maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT;" text="All Files" />
            <Button maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT;" text="Java Project" />
            <Button maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT;" text="Assignments" />
        </VBox>
    </left>

    <center>
        <TableView fx:id="fileTable">
            <columns>
                <TableColumn fx:id="nameColumn" prefWidth="250" text="File Name" />
                <TableColumn fx:id="typeColumn" prefWidth="100" text="Category" />
                <TableColumn fx:id="pathColumn" prefWidth="450" text="Location" />
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets top="5" right="10" bottom="5" left="10"/>
            </padding>
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #bdc3c7; -fx-font-size: 11;"/>
            <ProgressBar fx:id="progressBar" visible="false" prefWidth="200" />
        </HBox>
    </bottom>

</BorderPane>
